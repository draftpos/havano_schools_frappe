      <span class="nav-label">Exam Schedule</span>
    </a>
    <a class="nav-item" href="/portal-home-schedule" onclick="closeSidebar()">
      <div class="nav-icon">🏠</div>
      <span class="nav-label">Homework Schedule</span>
    </a>
    <a class="nav-item" href="/portal-test-schedule" onclick="closeSidebar()">
      <div class="nav-icon">📋</div>
