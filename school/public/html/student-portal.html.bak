  <div class="sidebar-footer">
    <div class="user-pill">
      <div class="user-avatar">S</div>
      <div class="user-info">
        <div class="user-name">Student</div>
        <div class="user-role">Student Portal</div>
      </div>
      <div class="user-status"></div>
    </div>
  </div>
</aside>

<!-- ═══════════ MAIN ═══════════ -->
<div class="main">

  <header class="topbar">
    <button class="menu-toggle" onclick="toggleSidebar()">☰</button>
    <div class="page-title">Student Portal</div>
    <div class="topbar-spacer"></div>
    <div class="topbar-right">
      <a class="tb-btn" href="/student-profile">👤 My Profile</a>
      <a class="tb-btn" href="/student-billing">💰 Billing</a>
    </div>
  </header>

  <div class="content">

    <!-- Hero Banner -->
    <div class="portal-hero">
      <div class="hero-inner">
        <div>
          <div class="hero-title">Welcome to Your Student Portal</div>
          <div class="hero-sub">Access all your academic and financial information in one place.</div>
          <div class="hero-btns">
            <a href="/student-profile" class="hero-btn hero-btn-light">👤 My Profile</a>
            <a href="/student-billing" class="hero-btn hero-btn-outline">💰 Billing</a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="hero-stat-box">
            <div class="hero-stat-icon">📅</div>
            <div class="hero-stat-label">Exams</div>
          </div>
          <div class="hero-stat-box">
            <div class="hero-stat-icon">📚</div>
            <div class="hero-stat-label">Homework</div>
          </div>
          <div class="hero-stat-box">
            <div class="hero-stat-icon">📊</div>
            <div class="hero-stat-label">Results</div>
          </div>
          <div class="hero-stat-box">
            <div class="hero-stat-icon">💰</div>
            <div class="hero-stat-label">Finance</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Two column layout -->
    <div class="two-col">
      <!-- Left: quick links + help -->
      <div >
        <div class="sec-head">
          <div class="sec-title"><span></span>Quick Links</div>
        </div>

        <div class="actions-grid">
          <a href="/portal-exam-schedule" class="action-card">
            <div class="action-icon">🏫</div>
            <div class="action-label">Exam Schedule</div>
          </a>
          <a href="/portal-home-schedule" class="action-card">
            <div class="action-icon">🏠</div>
            <div class="action-label">Homework Schedule</div>
          </a>
          <a href="/portal-test-schedule" class="action-card">
            <div class="action-icon">📋</div>
            <div class="action-label">Class Test Schedule</div>
          </a>
          <a href="/exam-results" class="action-card">
            <div class="action-icon">📊</div>
            <div class="action-label">Exam Results</div>
          </a>
          <a href="/class-test-results" class="action-card">
            <div class="action-icon">🏆</div>
            <div class="action-label">Class Test Results</div>
          </a>
          <a href="/homework-results" class="action-card">
            <div class="action-icon">📚</div>
            <div class="action-label">Homework Results</div>
          </a>
          <a href="/student-billing" class="action-card">
            <div class="action-icon">💰</div>
            <div class="action-label">Account Statement</div>
          </a>
          <a href="/student-profile" class="action-card">
            <div class="action-icon">👤</div>
            <div class="action-label">My Profile</div>
          </a>
        </div>

        <div class="sec-head" style="margin-top:8px;">
          <div class="sec-title"><span></span>Help &amp; Info</div>
        </div>
        <div class="help-card">
          <div class="help-row">
            <div class="help-icon">📞</div>
            <div class="help-text">
              <strong>School Contact</strong>
              <p>For any issues contact the school administration.</p>
            </div>
          </div>
          <div class="help-row">
            <div class="help-icon">🔒</div>
            <div class="help-text">
              <strong>Keep your login details safe.</strong>
              <p>Never share your password with anyone.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: cards -->
      <div >

        <!-- Schedules -->
        <div class="sec-head">
          <div class="sec-title"><span></span>Schedules</div>
        </div>
        <div class="cards-grid" style="margin-bottom:28px;">
          <a class="portal-card pc-blue" href="/portal-exam-schedule">
            <div class="pc-icon-wrap">🏫</div>
            <div class="pc-title">Exam Schedule</div>
            <div class="pc-desc">View upcoming exams, dates and rooms.</div>
            <span class="pc-btn">View →</span>
          </a>
          <a class="portal-card pc-amber" href="/portal-home-schedule">
            <div class="pc-icon-wrap">🏠</div>
            <div class="pc-title">Homework Schedule</div>
            <div class="pc-desc">View your home assignment schedule.</div>
            <span class="pc-btn">View →</span>
          </a>
          <a class="portal-card pc-rose" href="/portal-test-schedule">
            <div class="pc-icon-wrap">📋</div>
            <div class="pc-title">Class Test Schedule</div>
            <div class="pc-desc">View upcoming class tests and dates.</div>
            <span class="pc-btn">View →</span>
          </a>
        </div>

        <!-- Results -->
        <div class="sec-head">
          <div class="sec-title"><span></span>Results</div>
        </div>
        <div class="cards-grid" style="margin-bottom:28px;">
          <a class="portal-card pc-violet" href="/exam-results">
            <div class="pc-icon-wrap">📊</div>
            <div class="pc-title">Exam Results</div>
            <div class="pc-desc">Check your exam marks and grades.</div>
            <span class="pc-btn">View →</span>
          </a>
          <a class="portal-card pc-indigo" href="/class-test-results">
            <div class="pc-icon-wrap">🏆</div>
            <div class="pc-title">Class Test Results</div>
            <div class="pc-desc">View your class test performance.</div>
            <span class="pc-btn">View →</span>
          </a>
          <a class="portal-card pc-emerald" href="/homework-results">
            <div class="pc-icon-wrap">📚</div>
            <div class="pc-title">Homework Results</div>
            <div class="pc-desc">View your homework scores.</div>
            <span class="pc-btn">View →</span>
          </a>
        </div>

        <!-- Finance -->
        <div class="sec-head">
          <div class="sec-title"><span></span>Finance</div>
        </div>
        <div class="cards-grid-2">
          <a class="portal-card pc-amber" href="/student-billing">
            <div class="pc-icon-wrap">💰</div>
            <div class="pc-title">Account Statement</div>
            <div class="pc-desc">View your fee statements and invoices.</div>
            <span class="pc-btn">View →</span>
          </a>
          <a class="portal-card pc-cyan" href="/student-profile">
            <div class="pc-icon-wrap">👤</div>
            <div class="pc-title">My Profile</div>
            <div class="pc-desc">View your personal details and account info.</div>
            <span class="pc-btn">View →</span>
          </a>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('open');
}
function setActive(el) {
  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
}
</script>
</body>
</html>